# ===== Auth (JWT custom) =====
# Secret for signing JWT tokens (min 32 chars, use a random string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Anniversary/start date for the "Tiempo juntos" counter (ISO format)
TOGETHER_SINCE=2024-01-01T00:00:00Z

# User 1 credentials (her)
HER_USERNAME=ella
HER_PASSWORD=change-me

# User 2 credentials (him)
HIS_USERNAME=el
HIS_PASSWORD=change-me

# ===== Supabase (database only, server-side) =====
# Get these from: Supabase Dashboard → Settings → API
# Use the service_role key (secret), NOT the anon/publishable key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
