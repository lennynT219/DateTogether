---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimeCounter from '../components/TimeCounter.astro';

export const prerender = false;

const togetherSince = import.meta.env.TOGETHER_SINCE || '2024-01-01T00:00:00Z';
---

<BaseLayout>
  <main class="login-page">
    <!-- Decorative shapes over the background -->
    <div class="bg-pattern">
      <div class="bg-shape bg-shape--1"></div>
      <div class="bg-shape bg-shape--2"></div>
      <div class="bg-shape bg-shape--3"></div>
    </div>

    <div class="login-card">
      <div class="login-card__inner">
        <h1>Tiempo juntos</h1>
        <TimeCounter togetherSince={togetherSince} client:load />

        <form id="login-form" class="login-form">
          <div class="form-group">
            <label for="username">Usuario</label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="Tu nombre de usuario"
              autocomplete="username"
              required
            />
          </div>

          <div class="form-group">
            <label for="password">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Tu contraseña"
              autocomplete="current-password"
              required
            />
          </div>

          <div id="login-error" class="login-error" style="display: none;"></div>

          <button type="submit" class="login-button">
            Ingresar
          </button>
        </form>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('login-error') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.style.display = 'none';

    const username = (document.getElementById('username') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const response = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password }),
      });

      if (response.ok) {
        window.location.href = '/';
      } else {
        const data = await response.json();
        errorEl.textContent = data.error || 'Error al iniciar sesión';
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.textContent = 'Error de conexión';
      errorEl.style.display = 'block';
    }
  });
</script>

<style>
  /* ===== Background with couple photo ===== */
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    position: relative;
    overflow: hidden;
    /* Photo background — place your image at /public/images/couple.webp */
    background: url('/images/couple.webp') center / cover no-repeat;
  }

  /* Subtle warm overlay — keeps it readable but photo stays visible */
  .login-page::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 30%, rgba(107, 79, 46, 0.25) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(196, 168, 130, 0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(62, 42, 30, 0.35) 0%, transparent 60%);
    pointer-events: none;
  }

  /* ===== Decorative geometric pattern (visible through glass) ===== */
  .bg-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .bg-shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.12;
  }

  .bg-shape--1 {
    width: 500px;
    height: 500px;
    background: var(--color-accent, #C4A882);
    top: -150px;
    right: -100px;
  }

  .bg-shape--2 {
    width: 300px;
    height: 300px;
    background: var(--color-accent-light, #E8DCC8);
    bottom: -80px;
    left: -60px;
  }

  .bg-shape--3 {
    width: 200px;
    height: 200px;
    background: var(--color-primary, #8B6F47);
    top: 40%;
    left: 10%;
    opacity: 0.08;
  }

  /* ===== Apple Liquid Glass card ===== */
  .login-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    /* Core: very translucent + softer blur + heavy saturation = the Apple look */
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border-radius: 28px;
    /* Very subtle border — the white ring is the inset shadow, not the border */
    border: 1px solid rgba(255, 255, 255, 0.18);
    /* The "Apple ring" — inner highlight + soft drop */
    box-shadow:
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.5),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.4),
      inset 0 -1px 0 0 rgba(0, 0, 0, 0.04),
      0 20px 60px rgba(62, 42, 30, 0.25),
      0 4px 16px rgba(62, 42, 30, 0.1);
  }

  /* Iridescent sheen — diagonal light catch, very subtle */
  .login-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 28px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.35) 0%,
      rgba(255, 255, 255, 0.05) 25%,
      transparent 50%,
      rgba(196, 168, 130, 0.06) 75%,
      rgba(255, 255, 255, 0.2) 100%
    );
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: overlay;
  }

  .login-card__inner {
    position: relative;
    z-index: 1;
    padding: 2.5rem 2rem;
    text-align: center;
  }

  .login-card h1 {
    font-size: 1.6rem;
    font-weight: 600;
    color: #FFFFFF;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }

  /* ===== Form ===== */
  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .form-group {
    text-align: left;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted, #8B7D6B);
  }

  .form-group input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 12px;
    font-size: 0.95rem;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--color-text, #3E2A1E);
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    box-sizing: border-box;
  }

  .form-group input::placeholder {
    color: var(--color-text-muted, #8B7D6B);
    opacity: 0.5;
  }

  .form-group input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.4);
    box-shadow:
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.6),
      0 0 0 3px rgba(139, 111, 71, 0.1);
  }

  /* ===== Error ===== */
  .login-error {
    background: var(--color-error-bg, #FDF0ED);
    color: var(--color-error, #C0392B);
    padding: 0.7rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid rgba(192, 57, 43, 0.15);
  }

  /* ===== Button ===== */
  .login-button {
    background: var(--color-primary, #8B6F47);
    color: #fff;
    border: none;
    padding: 0.85rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    letter-spacing: 0.02em;
  }

  .login-button:hover {
    background: var(--color-primary-dark, #6B4F2E);
    transform: translateY(-1px);
  }

  .login-button:active {
    transform: translateY(0);
  }
</style>
