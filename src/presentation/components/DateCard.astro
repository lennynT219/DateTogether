---
import type { DateEntry } from '../../core/entities/DateEntry';

export interface Props {
  date: DateEntry;
}
const { date } = Astro.props;
const isCompleted = date.completed;
const isFree = date.category === 'free';
const displayTitle = isFree ? 'Espacio libre' : date.title;
---

<article
  class="date-card"
  data-date-id={date.id}
  data-completed={String(isCompleted)}
  data-category={date.category}
>
  <div class="date-card__media">
    {isCompleted ? (
      <div class="date-card__icon date-card__icon--completed">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
        </svg>
      </div>
    ) : (
      <div class="date-card__icon date-card__icon--locked">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
      </div>
    )}
  </div>
  <div class="date-card__info">
    <h3 class="date-card__title">{displayTitle}</h3>
    <span class={`date-card__badge ${isCompleted ? 'date-card__badge--completed' : 'date-card__badge--pending'}`}>
      {isCompleted ? 'Completada' : 'Pendiente'}
    </span>
  </div>
</article>

<style>
  .date-card {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(62, 42, 30, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    aspect-ratio: 3 / 4;
  }
  .date-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(62, 42, 30, 0.15);
  }
  .date-card__media {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F5F0E6;
  }
  .date-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .date-card__icon--locked {
    color: #8B7D6B;
    opacity: 0.6;
  }
  .date-card__icon--completed {
    color: #8B6F47;
    opacity: 0.8;
  }
  .date-card__info {
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: rgba(255, 255, 255, 0.95);
  }
  .date-card__title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #3E2A1E;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .date-card__badge {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    align-self: flex-start;
  }
  .date-card__badge--pending {
    background: rgba(139, 111, 71, 0.1);
    color: #8B6F47;
  }
  .date-card__badge--completed {
    background: rgba(76, 175, 80, 0.1);
    color: #4CAF50;
  }
</style>
